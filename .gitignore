```
# Dependencies
vendor/

# Logs
*.log

# Environment
.env
.env.local
.env.*

# Cache
.cache/
.phpunit.result.cache

# OS generated files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
target/

# Python artifacts (if any Python files present)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Node artifacts (if any JS files present)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled binary files
*.exe
*.dll
*.so
*.dylib

# Coverage directory used by tools like istanbul
coverage/
```